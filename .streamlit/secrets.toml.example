GEMINI_API_KEY = "paste_your_gemini_api_key_here"

# Optional. The app defaults to gemini-2.5-flash if this is not set.
GEMINI_MODEL = "gemini-2.5-flash"

# Optional. Add your Google Analytics 4 measurement ID to track public demo visits.
GA4_MEASUREMENT_ID = "G-XXXXXXXXXX"

# Optional. Add a GA4 Measurement Protocol API secret for more reliable server-side tracking.
# Create this in GA4: Admin > Data streams > your web stream > Measurement Protocol API secrets.
GA4_API_SECRET = "paste_your_ga4_api_secret_here"
